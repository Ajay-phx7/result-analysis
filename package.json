{
  "name": "result-analysis-orchestrator",
  "version": "1.0.0",
  "private": true,
  "description": "Orchestrator package for Result Analysis web application",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "seed:backend": "npm run seed --prefix backend",
    "prisma:generate": "npx prisma generate --schema=backend/prisma/schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --schema=backend/prisma/schema.prisma"
  }
}
